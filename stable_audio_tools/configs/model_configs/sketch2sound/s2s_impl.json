{
    "sample_size": 524288,
    "sample_rate": 44100,
    "audio_channels": 2,
    "model": {
        "pretransform": {
            "type": "autoencoder",
            "iterate_batch": true,
            "config": {
                "encoder": {
                    "type": "oobleck",
                    "config": {
                        "in_channels": 2,
                        "channels": 128,
                        "c_mults": [1, 2, 4, 8, 16],
                        "strides": [2, 4, 4, 8, 8],
                        "latent_dim": 128,
                        "use_snake": true
                    }
                },
                "decoder": {
                    "type": "oobleck",
                    "config": {
                        "out_channels": 2,
                        "channels": 128,
                        "c_mults": [1, 2, 4, 8, 16],
                        "strides": [2, 4, 4, 8, 8],
                        "latent_dim": 64,
                        "use_snake": true,
                        "final_tanh": false
                    }
                },
                "latent_dim": 64,
                "downsampling_ratio": 2048,
                "io_channels": 2
            }
        },
        "conditioning": {
            "configs": [
                {
                    "id": "prompt",
                    "type": "t5",
                    "config": {
                        "output_dim": 768,
                        "t5_model_name": "t5-base",
                        "max_length": 128,
                        "enable_grad": false,
                        "project_out": false
                    }
                },
                {
                    "id": "seconds_start",
                    "type": "number",
                    "config": {
                        "output_dim": 768,
                        "min_val": 0,
                        "max_val": 512
                    }
                },
                {
                    "id": "seconds_total",
                    "type": "number",
                    "config": {
                        "output_dim": 768,
                        "min_val": 0,
                        "max_val": 512
                    }
                }
            ]
        },
        "diffusion": {
            "cross_attention_cond_ids": ["prompt", "seconds_start", "seconds_total"],
            "global_cond_ids": ["seconds_start", "seconds_total"],
            "prepend_cond_ids": [],
            "input_concat_ids": [],
            "config": {
                "io_channels": 64,
                "embed_dim": 1536,
                "depth": 24,
                "num_heads": 24,
                "cond_token_dim": 768,
                "global_cond_dim": 1536,
                "project_cond_tokens": false,
                "transformer_type": "continuous_transformer"
            }
        },
        "io_channels": 64
    },
    "training": {
        "use_ema": true,
        "cfg_dropout_prob" : 0.05,
        "validation_timesteps": [0.1, 0.3, 0.5, 0.7, 0.9],
        "optimizer_configs": {
            "diffusion": {
                "optimizer": {
                    "type": "AdamW",
                    "config": {
                        "lr": 1e-5,
                        "betas": [0.9, 0.999],
                        "weight_decay": 1e-4
                    }
                },
                "scheduler": {
                    "type": "CosineAnnealingLR",
                    "config": {
                        "T_max": 40000,
                        "eta_min": 1e-7
                    }
                }
            }
        },
        "demo": {
            "demo_every": 100,
            "demo_steps": 250,
            "demo_cfg_scales_text": [3, 6, 9],
            "demo_cfg_scales_controls": [1, 3, 6],
            "clap_ckpt_path": "/home/stud/dco/storage/user/dco/clap_score/630k-audioset-fusion-best.pt",
            "outdir":"outdir/demo",
            "demo_cond": [
                {"prompt": "car racing", "control_signal": "/home/stud/dco/Desktop/s2s-2/Controllable-Audio-Generation-from-Sonic-Imitations/sounds/car.wav"},
                {"prompt": "forest ambience", "control_signal":"/home/stud/dco/Desktop/s2s-2/Controllable-Audio-Generation-from-Sonic-Imitations/sounds/forest.wav"},
                {"prompt": "bass drum, snare drum", "control_signal":"/home/stud/dco/Desktop/s2s-2/Controllable-Audio-Generation-from-Sonic-Imitations/sounds/drum.wav"}
            ]
        }
    }
}